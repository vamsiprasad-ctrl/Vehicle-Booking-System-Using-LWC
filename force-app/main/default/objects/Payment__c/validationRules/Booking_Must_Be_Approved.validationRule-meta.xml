<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Booking_Must_Be_Approved</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISPICKVAL(Booking__r.Status__c, &quot;Approved&quot;)),
  NOT(ISPICKVAL(Booking__r.Status__c, &quot;Delivered&quot;))
)</errorConditionFormula>
    <errorMessage>Payment can only be added to an Approved or Delivered booking</errorMessage>
</ValidationRule>
