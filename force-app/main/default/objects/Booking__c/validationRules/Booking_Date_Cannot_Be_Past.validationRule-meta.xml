<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Booking_Date_Cannot_Be_Past</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISNEW()),
  Booking_Date__c &lt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>Booking_Date__c</errorDisplayField>
    <errorMessage>Booking date cannot be set in the past</errorMessage>
</ValidationRule>
